# ── Supabase (service role — server only, never expose publicly) ────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Resend ──────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=MakeVision <noreply@yourdomain.com>

# ── App ─────────────────────────────────────────────────────────────────────────
APP_URL=https://yourdomain.com

# ── Audio ───────────────────────────────────────────────────────────────────────
# Place 852Hz audio files (.mp3/.wav/.aac) in ./audio/ folder
# The worker picks one at random for each video
